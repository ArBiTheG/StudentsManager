<Window x:Class="StudentsManagerApp.View.DialogWindows.DiplomaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentsManagerApp.View.DialogWindows"
        mc:Ignorable="d"
        Title="DiplomaWindow" Height="450" Width="800">
    <Window.Resources>
        <Style TargetType="ScrollViewer">
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Width" Value="96" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Height" Value="32" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Height" Value="32" />
        </Style>
        <Style TargetType="TextBox" x:Key="Description">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Height" Value="64" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Height" Value="32" />
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Height" Value="32" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="128"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Обучающийся"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Серия документа"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Номер документа"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата вручения"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Школа"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Наименование документа"/>
                <ComboBox Grid.Row="0" Grid.Column="1" SelectedItem="{Binding Diploma.Person}" ItemsSource="{Binding Persons}" DisplayMemberPath="FullName">
                </ComboBox>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Diploma.Series}"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Diploma.Number}"/>
                <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding Diploma.Given}"/>
                <ComboBox Grid.Row="4" Grid.Column="1" SelectedItem="{Binding Diploma.School}" ItemsSource="{Binding Schools}" DisplayMemberPath="ShortName">
                </ComboBox>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Diploma.Name}"/>
                <Button Grid.Row="0" Grid.Column="2" Command="{Binding AddPersonCommand}">Создать</Button>
                <Button Grid.Row="4" Grid.Column="2" Command="{Binding AddSchoolCommand}">Создать</Button>
            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Button IsDefault="True" Click="Accept_Click">ОК</Button>
            <Button IsCancel="True">Отмена</Button>
        </StackPanel>
    </Grid>
</Window>
